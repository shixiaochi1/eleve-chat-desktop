{
  "rules": {
    "no-emoji": "禁止在 UI 中使用 Emoji，统一使用 lucide-react",
    "icon-style": "strokeWidth=1.5, 集中管理在 Icons.jsx",
    "design-system": "Apple macOS 风格, dark #1c1c1e / light #f5f5f7",
    "context-bar": "ContextBar 替代 ChatToolbar，始终可见",
    "command-routing": "/ 开头消息走 /v1/command，禁止走 /v1/chat/stream"
  }
}
